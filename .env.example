GOOGLE_CLIENT_ID=seu-client-id-google
GOOGLE_CLIENT_SECRET=seu-client-secret-google
AUTH_SECRET=gere-uma-string-grande-aleatoria
APP_URL=http://localhost:3000

# Criado automaticamente ao conectar Vercel Postgres/Neon no projeto Vercel.
POSTGRES_URL=postgres://usuario:senha@host/database

# Mercado Pago Assinaturas.
# Teste: use token TEST- e configure um comprador de teste.
# Produção: use token APP_USR- e deixe os campos de teste vazios.
MERCADO_PAGO_ACCESS_TOKEN=TEST-seu-access-token
MERCADO_PAGO_WEBHOOK_SECRET=
MERCADO_PAGO_TEST_PAYER_USER=
MERCADO_PAGO_TEST_PAYER_EMAIL=
