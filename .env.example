GOOGLE_CLIENT_ID=seu-client-id-google
GOOGLE_CLIENT_SECRET=seu-client-secret-google
AUTH_SECRET=gere-uma-string-grande-aleatoria
APP_URL=http://localhost:3000

# Criado automaticamente ao conectar Vercel Postgres/Neon no projeto Vercel.
POSTGRES_URL=postgres://usuario:senha@host/database

# Mercado Pago: use credenciais de produção para receber pagamentos reais.
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-seu-access-token
MERCADO_PAGO_WEBHOOK_SECRET=seu-segredo-de-webhook

# Kimi/Moonshot AI: configure somente no backend/Vercel.
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.5
AI_ADMIN_EMAILS=
AI_ADMIN_USER_IDS=
